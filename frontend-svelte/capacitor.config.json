{
  "appId": "site.suluk.app",
  "appName": "Suluk",
  "webDir": "dist",
  "server": {
    "url": "https://suluk.site/mobile",
    "allowNavigation": ["suluk.site", "*.suluk.site", "app.pakasir.com"],
    "androidScheme": "https"
  },
  "backgroundColor": "#0F3D2E",
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "launchAutoHide": true,
      "backgroundColor": "#0F3D2E",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#0F3D2E"
    }
  }
}
