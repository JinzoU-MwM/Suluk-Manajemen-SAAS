{
  "name": "frontend-svelte",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
    "lint": "npm run check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:all": "npm run check && npm run test",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync",
    "cap:sync": "npm run build && cap sync",
    "cap:android": "npm run build && cap sync android && cap open android",
    "android:open": "cap open android"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.2.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.64.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "svelte": "^5.43.8",
    "svelte-check": "^4.4.4",
    "tailwindcss": "^3.4.0",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/core": "^6.2.1",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@neodrag/svelte": "^2.0.0",
    "gsap": "^3.15.0",
    "lucide-svelte": "^0.563.0"
  }
}
