{
  "title": "Jamaah Backend Baseline",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Requests Rate",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m]))",
          "legendFormat": "rps"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Error Rate (%)",
      "targets": [
        {
          "expr": "100 * sum(rate(http_errors_total[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1)",
          "legendFormat": "error_rate_pct"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP p95 Latency (s)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Gemini Calls Rate",
      "targets": [
        {
          "expr": "sum(rate(gemini_calls_total[5m]))",
          "legendFormat": "calls_per_sec"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Gemini Cache Hit Ratio",
      "targets": [
        {
          "expr": "sum(rate(gemini_cache_requests_total{result=\"hit\",cache_mode=\"default\"}[5m])) / clamp_min(sum(rate(gemini_cache_requests_total{cache_mode=\"default\"}[5m])), 1)",
          "legendFormat": "hit_ratio"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Gemini Cache Mode Mix",
      "targets": [
        {
          "expr": "sum(rate(gemini_cache_requests_total[5m])) by (cache_mode)",
          "legendFormat": "{{cache_mode}}"
        }
      ]
    }
  ]
}
